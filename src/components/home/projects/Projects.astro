---
import { projects } from "../../../data/home/projects/projects"
import type { Project } from "../../../data/home/projects/projects"
import Image from "astro/components/Image.astro"
---

<section id="projects" class=" max-w-8xl mx-auto px-10 py-32 bg-section-background scroll-mt-12">
  <div class=" mb-16">
    <h2 class="font-family-secondary text-4xl font-bold">PROYECTOS</h2>
  </div>
  <div class="grid grid-cols-6 gap-6">
    {
      projects.map((project: Project) => (
        <article
          class={
            "bg-[#2D3449] rounded-lg overflow-hidden " +
            (project.id === 1
              ? "col-span-4"
              : project.id === 2
                ? "col-span-2"
                : "col-span-3")
          }
        >
          <div class={ project.id === 3 || project.id === 4 ? "flex flex-col-reverse p-8" : "" }>
            <Image
              src={project.image}
              alt={project.title}
              class={ " " +  (project.id === 3 || project.id === 4 ? "max-w-full max-h-80 mt-4 rounded" : "w-full object-cover mb-4") }
              loading="lazy" 
            />
            <div class={ "flex flex-col gap-4 " + (project.id === 3 || project.id === 4 ? "p-0" : "p-8") }>
              <div>
                {
                  project.stack.map((tech) => (
                    <span 
                      class="text-sm bg-stack-background py-1 px-3 text-custom-green-light 
                      mr-2 rounded-xs"
                    >
                      {tech}
                    </span>
                  ))
                }
              </div>
              <h3 class="font-family-secondary tracking-widest text-3xl font-bold">{project.title}</h3>
              <p class="text-custom-gray-light">{project.description}</p>
              <a href={project.linkDeploy} class="text-custom-green-light hover:underline">Ver proyecto</a>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>