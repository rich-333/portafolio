---
import { aboutMe } from "../../../data/home/about-me/aboutMe"
import type { AboutMe } from "../../../data/home/about-me/aboutMe"
---

<section id="about" class="min-h-screen bg-[#0B1326] scroll-mt-90 md:scroll-mt-12">
  <div class="grid xl:grid-cols-[468px_1fr] gap-20 max-w-8xl mx-auto px-10 py-32">
    <div class=" flex flex-col gap-8">
      <h2 class="font-family-secondary text-4xl font-bold">SOBRE_MÍ</h2>
      <div class=" bg-custom-green-light h-1 w-20"></div>
      <div class=" flex flex-col gap-4 text-custom-gray-light text-sm font-normal">
        <p>[01] // LOCALIZACION: COCHABAMBA_BO</p>
        <p>[02] // ESTADO: DISPONIBLE_PARA_CONTRATAR</p>
        <p>[03] // ROL: FULL_STACK_DEVELOPER</p>
      </div>
    </div>

    <div class=" flex flex-col gap-12 w-full">
      <div>
        <article class="bg-section-background p-10 flex flex-col gap-8 rounded-lg">
          <h3 class=" text-2xl font-normal leading-relaxed">
              Soy desarrollador Full Stack junior y estudiante de Ingeniería de Sistemas.
              Me gusta construir aplicaciones  con una <span class="text-custom-green">base sólida</span>
              y una <span class="text-custom-green">interfaz clara</span>.
          </h3>
          <div class=" flex justify-between gap-8 text-custom-gray-light">
              <p class="leading-relaxed">
                En el backend disfruto diseñar bases de datos, implementar la lógica de negocio y desarrollar APIs que permitan construir aplicaciones organizadas y fáciles de mantener. Trabajo principalmente con Laravel, PostgreSQL y MySQL.
              </p>
              <p class="leading-relaxed">
                En el frontend busco crear interfaces rápidas, claras y responsivas utilizando React y Astro. También trabajo con Tailwind CSS y SCSS, manteniendo un código ordenado y un flujo de trabajo apoyado en Git y Linux.
              </p>
          </div>
        </article>
      </div>

      <div class=" flex flex-col md:flex-row gap-4">
        {
          aboutMe.map(({ title, description, icon }: AboutMe) => (
            <article class="bg-section-background p-6 flex flex-col items-start gap-4 rounded-lg">
              <iconify-icon
                icon={icon} 
                width="24" 
                height="24"
                class="text-custom-green"
              ></iconify-icon>
              <h4 class="font-family-secondary tracking-widest text-sm font-bold">{title}</h4>
              <p class=" text-custom-gray-light leading-relaxed">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>