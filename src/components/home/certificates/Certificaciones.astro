---
import type { Certificacion } from "../../../data/home/cerificaciones/certificaciones"
import { certificaciones } from "../../../data/home/cerificaciones/certificaciones"
import Image from "astro/components/Image.astro"
---

<section id="certificates" class="min-h-screen max-w-8xl mx-auto p-32 flex flex-col gap-12 bg-stack-background relative ">
  <div>
    <h2 class=" font-family-secondary text-4xl font-bold">CERTIFICACIONES</h2>
  </div>

  <div 
    id="certificationCont"
    class="flex flex-col gap-4"
  >
    {
      certificaciones.map(({ id, issued, name, organization, url, img, leftBorderColor, issuedColor }: Certificacion, index) => (
        <a 
          class={`certification bg-section-background border-l-4 ${leftBorderColor} ${index >= 3 ? "no_show" : ""}`} 
          href={url} 
          target="_blank" 
          rel="noopener noreferrer"
        >
          <article class=" p-6 rounded flex justify-between items-center">
            <div class=" flex flex-col gap-1">
              <p class={`uppercase ${issuedColor} text-xs font-normal`}>{issued}</p>
              <h3 class="font-family-secondary tracking-widest font-bold text-lg">{name}</h3>
              <p class="text-custom-gray-light font-normal">{organization}</p>
            </div>

            <div>
              <Image 
                src={img} 
                alt={name}
                width="90"
                height="68"
                loading="lazy"
              />
            </div>
          </article>
        </a>
      ))
    }
    
  </div>

  <div 
    class="absolute bottom-10 left-1/2 -translate-x-1/2 
      text-custom-green-light hover:text-custom-green-light/80 group">
    <button 
      id="btnCertificate"
      class="flex items-center gap-2 whitespace-nowrap font-bold cursor-pointer 
        transition-colors duration-300 text-sm"
    >
      <iconify-icon id="iconShow" icon="mdi:show" width="18" height="18"></iconify-icon>
      VER_MÁS
      
    </button>
    <span class="absolute -bottom-1 left-0 h-0.5 bg-custom-green transition-all duration-300 w-full group-hover:w-0"></span>
  </div>
</section>

<script>
  const certifications = document.querySelectorAll(".certification");
  const btnCertificate = document.getElementById("btnCertificate");
  const sectionCertificates = document.getElementById("certificates");
  const iconShow = document.getElementById("iconShow");

  certifications.forEach((certification, index) => {
    certification.addEventListener("mouseover", () => {
      certification.classList.add("hovered");
    });
    certification.addEventListener("mouseout", () => {
      certification.classList.remove("hovered");
    });

  });

  let isExpanded = false;

  btnCertificate?.addEventListener("click", () => {
    isExpanded = !isExpanded;

    certifications.forEach((certification, index) => {
      if (index >= 3) {
        if (isExpanded) {
          certification.classList.remove("no_show");
          setTimeout(() => certification.classList.add("show"), 10);
        } else {
          certification.classList.remove("show");
          certification.classList.add("no_show");
        }
      }
    });

    if (isExpanded) {
      sectionCertificates?.classList.remove("min-h-screen");
      btnCertificate.innerHTML = `<iconify-icon id="iconShow" icon="mdi:hide" width="18" height="18"></iconify-icon>VER_MENOS`;
    } else {
      sectionCertificates?.classList.add("min-h-screen");
      btnCertificate.innerHTML = `<iconify-icon id="iconShow" icon="mdi:show" width="18" height="18"></iconify-icon>VER_MÁS`;
      sectionCertificates?.scrollIntoView({ behavior: 'smooth' });
    }
  });
</script>

<style>
  .hovered:hover {
    transform: translateX(-5px);
  }

  .certification {
    transition: all 0.4s ease;
    opacity: 1;
    transform: translateY(0);
  }

  .no_show {
    display: none;
    opacity: 0;
    transform: translateY(-10px);
  }

  .show {
    display: initial;
    opacity: 1;
    transform: translateY(0);
  }
</style>