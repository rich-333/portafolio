---
import '../styles/global.css';
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';
import iconifyUrl from '../scripts/iconify.ts?url';
---

<!doctype html>
<html lang="es" class="">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>Richard P. | Full Stack Developer</title>
		<meta
			name="description"
			content="Portafolio de Richard P., estudiante de Ingeniería de Sistemas y desarrollador Full Stack. Proyectos desarrollados con Laravel, React, Astro y .NET."
		/>
		<meta
			name="keywords"
			content="Portafolio, Full Stack, Laravel, React, Astro, .NET, C#, PostgreSQL, MySQL, Desarrollo Web"
		/>

		<meta name="author" content="Richard P." />
  	<meta name="robots" content="index, follow" />
  	<meta name="theme-color" content="#09090B" />

  	<link rel="canonical" href="https://tu-dominio.com/" />
		
		<script type="module" src={iconifyUrl}></script>
	</head>
	<body class="bg-background font-family-primary">
		<Header/>
			<main>
				<slot />
			</main>
		<Footer/>
	</body>
</html>

